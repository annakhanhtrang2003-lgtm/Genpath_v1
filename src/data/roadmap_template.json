  "priority_logic": {
    "_doc": "Giải quyết vấn đề quá nhiều skills cùng Priority 1 khi merge breed + major overlays",

    "algorithm": {
      "step_1": {
        "name": "Primary Sort: priority",
        "rule": "priority 1 (must-have) → 2 (strong advantage) → 3 (nice-to-have)",
        "type": "ascending"
      },
      "step_2": {
        "name": "Secondary Sort: time_estimate_weeks",
        "rule": "Within same priority, shorter skills first — user sees quick progress early",
        "type": "ascending",
        "rationale": "Giúp user hoàn thành skill nhanh nhất trước → motivation loop"
      },
      "step_3": {
        "name": "Tertiary Sort: is_quick_win",
        "rule": "Within same priority + time: quick_wins (true) hiện trước non-quick-wins",
        "type": "boolean, true first"
      },
      "step_4": {
        "name": "Quaternary Sort: category weight",
        "rule": "core > tool > power > soft (within same priority/time/quickwin)",
        "category_weights": { "core": 4, "tool": 3, "power": 2, "soft": 1 }
      }
    },

    "implementation": "function sortSkills(skills) {\n  const catWeight = { core: 4, tool: 3, power: 2, soft: 1 };\n  return skills.sort((a, b) => {\n    // Step 1: priority ascending\n    if (a.priority !== b.priority) return a.priority - b.priority;\n    // Step 2: time ascending\n    if (a.time_estimate_weeks !== b.time_estimate_weeks) return a.time_estimate_weeks - b.time_estimate_weeks;\n    // Step 3: quick_win first\n    if (a.is_quick_win !== b.is_quick_win) return a.is_quick_win ? -1 : 1;\n    // Step 4: category weight descending\n    return (catWeight[b.category] || 0) - (catWeight[a.category] || 0);\n  });\n}",

    "max_priority_1_per_phase": 3,
    "rule": "Nếu sau merge (breed + major) có > 3 skills priority 1 trong 1 phase → auto-demote skill có time_estimate_weeks cao nhất xuống priority 2",
    "overflow_implementation": "function enforceMaxPriority(skills, maxP1PerPhase = 3) {\n  const p1 = skills.filter(s => s.priority === 1).sort((a,b) => b.time_estimate_weeks - a.time_estimate_weeks);\n  while (p1.length > maxP1PerPhase) {\n    const demoted = p1.shift();\n    demoted.priority = 2;\n    demoted.priority_note = 'Auto-demoted: quá nhiều P1 trong phase';\n  }\n  return skills;\n}"
  },

